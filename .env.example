# ml-ai-ops-platform environment. Copy to .env and fill in.
# .env is gitignored — never commit it.

# ---- public hosting (compose.public.yaml) ----------------------------------
# DNS name pointing at this VM; Caddy provisions TLS for it automatically.
MLAIOPS_DOMAIN=platform.example.com
MLAIOPS_ACME_EMAIL=you@example.com

# OIDC (Dex) console login.
DEX_ADMIN_EMAIL=you@example.com
# bcrypt hash; generate with:
#   docker run --rm httpd:2.4-alpine htpasswd -bnBC 10 "" 'your-password' | tr -d ':\n'
DEX_ADMIN_PASSWORD_HASH=
# random secret for the console OAuth client, e.g. `openssl rand -hex 24`
DEX_CLIENT_SECRET=

# Shared bearer token protecting internal service APIs, e.g. `openssl rand -hex 24`
# Services presenting it get the "service" role (reporting endpoints only).
MLAIOPS_INTERNAL_TOKEN=

# ---- RBAC ---------------------------------------------------------------------
# Roles: admin | operator (full control), engineer (ML lifecycle, no platform
# connections), viewer (read-only). In OIDC mode roles come from the token's
# "roles" (or "groups") claim — grant them in Dex/your IdP. Locally, without
# OIDC, every request acts as MLAIOPS_LOCAL_ROLE (default: admin).
#MLAIOPS_LOCAL_ROLE=admin

# ---- LLM providers (agents) -------------------------------------------------
# Backend: openai | anthropic | openai-compatible | mock (default: mock, no keys needed)
MLAIOPS_LLM_BACKEND=mock
MLAIOPS_LLM_MODEL=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Where agent LLM calls egress (default: the trace proxy for full capture).
#MLAIOPS_LLM_BASE_URL=http://trace-proxy:8081/v1
# Upstream the trace proxy forwards to (default: https://api.openai.com).
#LLM_UPSTREAM_URL=https://api.anthropic.com

# ---- Langfuse ----------------------------------------------------------------
# Local defaults exist; override both for anything public.
#LANGFUSE_PUBLIC_KEY=
#LANGFUSE_SECRET_KEY=
#LANGFUSE_NEXTAUTH_SECRET=
#LANGFUSE_SALT=
#LANGFUSE_INIT_USER_EMAIL=
#LANGFUSE_INIT_USER_PASSWORD=

# ---- serverless (OpenFaaS/faasd on the VM) -----------------------------------
#OPENFAAS_URL=http://faasd:8080
#OPENFAAS_USER=admin
#OPENFAAS_PASSWORD=

# ---- deterministic LLM cost rates (USD per 1k tokens) -------------------------
#MLAIOPS_COST_PER_1K_INPUT=0
#MLAIOPS_COST_PER_1K_OUTPUT=0

# ---- real-time demos -----------------------------------------------------------
# Wire the demos to live components once they exist:
#CALLCENTER_AGENT_ID=agt-...
#FRAUD_MODEL_ENDPOINT=http://mlaiops-serve-churn-classifier:5001
